# Variables de entorno — UBER Dashboard
# Copia este archivo como .env para desarrollo local.
# En Render, configura estas variables en: Dashboard > Environment.
#
# NOTA: Este archivo NO contiene valores reales. Es solo una plantilla.

# ── Obligatorias en Render ────────────────────────────────────
# Render asigna PORT automáticamente. No necesitas definirla manualmente.
# PORT=10000

# ── Opcionales para ajustar comportamiento ────────────────────

# Desactiva el recolector de métricas de Streamlit
STREAMLIT_SERVER_HEADLESS=true

# Fuerza output sin buffer (mejor para logs en Render)
PYTHONUNBUFFERED=1

# Si en el futuro usas autenticación, agrega aquí tus secrets:
# STREAMLIT_AUTH_SECRET=tu_secreto_aqui
